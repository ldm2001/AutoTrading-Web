# 한국투자증권 OpenAPI
APP_KEY=your_app_key_here
APP_SECRET=your_app_secret_here
CANO=your_account_number_8digits
ACNT_PRDT_CD=01

# 실전투자
URL_BASE=https://openapi.koreainvestment.com:9443
# 모의투자
# URL_BASE=https://openapivts.koreainvestment.com:29443

# Discord
DISCORD_WEBHOOK_URL=https://discordapp.com/api/webhooks/your_webhook_here

# AI
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash

# Security
# API_KEY 필수 — 미설정 시 매매 API(/api/trading/*) 전체 비활성화 (조회/시세만 동작)
# 생성 예시: openssl rand -hex 32
API_KEY=your_api_key_here
REDIS_PASSWORD=your_redis_password
ELASTIC_PASSWORD=your_elastic_password
GRAFANA_PASSWORD=your_grafana_password

# Trading Config
SYMBOL_LIST=005930,373220,035720,000660
TARGET_BUY_COUNT=3
BUY_PERCENT=0.33
# 장중 봇 예외 종료 시 백오프 재시작 (3회 한도). 끄려면 false
BOT_RESTART_ON_CRASH=true
